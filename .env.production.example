# ===================================================================
# MERN Mastery Academy — Production Environment Variables Template
# ===================================================================
# Copy this file to .env on your cloud host dashboard
# DO NOT commit real values — this file is an example only
# ===================================================================

# Server
PORT=10000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/mernmastery?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# ── URLs ──────────────────────────────────────────────────────────
# Set both to your deployed app URL (single-server deploy)
# e.g. https://mern-mastery-academy.onrender.com
FRONTEND_URL=https://YOUR_APP_NAME.onrender.com
APP_URL=https://YOUR_APP_NAME.onrender.com

# ── Email / SMTP ──────────────────────────────────────────────────
# Option A: SendGrid (recommended — free 100 emails/day)
#   Sign up: https://sendgrid.com → Settings → API Keys
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.REPLACE_WITH_YOUR_SENDGRID_KEY
SMTP_FROM=verify@yourdomain.com

# Option B: Gmail App Password
#   Enable 2FA → Google Account → Security → App Passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=yourname@gmail.com
